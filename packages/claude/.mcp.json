{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_TOKEN": "${GITHUB_TOKEN}" }
    },
    "honeybadger": {
      "command": "npx",
      "args": ["-y", "@honeybadger-io/mcp-server"],
      "env": { "HONEYBADGER_API_KEY": "${HONEYBADGER_API_KEY}" }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
